<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payment link</title>
    <style>
      body {
        font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        margin: 0;
        padding: 0;
        background-color: #f4f6f8;
      }
      .email-container {
        max-width: 600px;
        margin: 40px auto;
        background-color: #ffffff;
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
        color: #333;
      }
      .email-header {
        text-align: center;
        padding-bottom: 20px;
        border-bottom: 1px solid #eaeaea;
      }
      .email-header .checkmark {
        font-size: 32px;
        color: #4caf50;
        margin-bottom: 10px;
      }
      .email-header h2 {
        margin: 0;
        font-size: 24px;
        color: #2e7d32;
      }
      .email-body {
        padding: 25px 0;
        line-height: 1.7;
        font-size: 15px;
        color: #555;
      }
      .email-body p {
        margin: 12px 0;
      }
      .highlight {
        background-color: #f0f7f4;
        padding: 18px;
        border-radius: 8px;
        margin: 25px 0;
        border-left: 5px solid #4caf50;
      }
      .email-footer {
        text-align: center;
        font-size: 12px;
        color: #999;
        margin-top: 40px;
        padding-top: 15px;
        border-top: 1px solid #e0e0e0;
      }
      .support {
        color: #4caf50;
        font-weight: bold;
      }
      .website-link {
        text-decoration: none;
        color: #4caf50;
        font-weight: bold;
      }
    </style>
  </head>

  <body>
    <div class="email-container">
      <!-- Header -->
      <div class="email-header">
        <div class="checkmark">✔</div>
        <h2>Payment</h2>
      </div>

      <!-- Body -->
      <div class="email-body">
        <p>Dear <strong>User</strong>,</p>

        <p>
          Please use below link for payment.
          <strong><%= url %></strong> account.
        </p>

        <p>
          For any help, contact us at
          <span class="support">contact@upfinzo.com</span>.
        </p>

        <p>
          Thank you for staying connected with <strong><%= process.env.COMPANY_NAME %></strong>.<br />
          Warm regards,<br />
          <strong><%= process.env.COMPANY_NAME %> Team</strong><br />
          <a class="website-link" href="https://www.<%= process.env.COMPANY_NAME %>.com" target="_blank">www.<%= process.env.COMPANY_NAME %>.com</a>
        </p>
      </div>

      <!-- Footer -->
      <div class="email-footer">
        &copy; 2025 <%= process.env.COMPANY_NAME %>. All rights reserved.
      </div>
    </div>
  </body>
</html>
